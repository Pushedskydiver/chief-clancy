{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreWorkspaces": ["packages/chief-clancy"],
  "workspaces": {
    "packages/core": {
      "project": ["src/**/*.ts"]
    },
    "packages/terminal": {
      "project": ["src/**/*.ts"],
      "entry": [
        "src/hooks/esbuild.hooks.ts",
        "src/hooks/clancy-*/clancy-*.ts",
        "src/hooks/shared/*/index.ts"
      ]
    }
  }
}
