{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreDependencies": ["@changesets/cli"],
  "ignoreWorkspaces": ["packages/chief-clancy"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"]
    },
    "packages/core": {
      "project": ["src/**/*.ts"]
    },
    "packages/brief": {
      "project": ["src/**/*.ts"]
    },
    "packages/plan": {
      "project": ["src/**/*.ts"]
    },
    "packages/scan": {},
    "packages/dev": {
      "project": ["src/**/*.ts"],
      "entry": [
        "src/esbuild.runtime.ts",
        "src/entrypoints/dev.ts",
        "src/entrypoints/loop.ts"
      ]
    },
    "packages/terminal": {
      "project": ["src/**/*.ts", "test/**/*.ts"],
      "entry": [
        "src/hooks/esbuild.hooks.ts",
        "src/hooks/clancy-*/clancy-*.ts",
        "src/hooks/shared/*/index.ts",
        "src/runner/esbuild.runtime.ts",
        "src/entrypoints/implement.ts",
        "src/entrypoints/autopilot.ts"
      ]
    }
  }
}
