{
  "name": "@chief-clancy/dev",
  "version": "0.2.1",
  "private": false,
  "description": "Autonomous Ralph Wiggum execution surface for Claude Code — pick up tickets and execute them with judgment",
  "author": "Alex Clapperton",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pushedskydiver/chief-clancy.git",
    "directory": "packages/dev"
  },
  "homepage": "https://github.com/Pushedskydiver/chief-clancy#readme",
  "bugs": {
    "url": "https://github.com/Pushedskydiver/chief-clancy/issues"
  },
  "dependencies": {
    "@chief-clancy/core": "workspace:*",
    "@chief-clancy/scan": "workspace:*",
    "zod": "^4.3.6"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "dev",
    "executor",
    "autonomous",
    "slash-commands",
    "developer-tools"
  ],
  "type": "module",
  "bin": {
    "clancy-dev": "./bin/dev.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "src/commands",
    "src/workflows"
  ],
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && tsc --project tsconfig.build.json && tsc-alias --project tsconfig.build.json && node dist/esbuild.runtime.js",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
