{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "outDir": ".declarations",
    "paths": {
      "~/d/*": ["./src/*"],
      "~/c/*": ["../core/src/*"],
      "@chief-clancy/core": ["../core/src/index.ts"],
      "@chief-clancy/core/*": ["../core/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
