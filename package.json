{
  "name": "@chief-clancy/root",
  "version": "0.0.0",
  "private": true,
  "description": "Clancy monorepo — autonomous, board-driven development for Claude Code",
  "author": "Alex Clapperton",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "publint": "publint packages/core && publint packages/terminal",
    "attw": "attw --pack packages/core --ignore-rules cjs-resolves-to-esm no-resolution && attw --pack packages/terminal --ignore-rules cjs-resolves-to-esm no-resolution",
    "version:ci": "changeset version && tsx scripts/group-changelog.ts",
    "prepare": "husky"
  },
  "volta": {
    "node": "24.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.1",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-sonarjs": "^4.0.2",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "knip": "^6.0.3",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.1"
  }
}
